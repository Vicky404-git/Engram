#!/bin/bash
# engram - Terminal Wrapper for the Context Engine

BASE_URL="http://localhost:8080/api"

if [ "$1" == "push" ]; then
  type="$2"
  tags="$3"
  content="$4"
  parentId="$5"
  relation="$6"

  # 🔥 Convert "null" to actual null (important)
  if [ "$parentId" == "null" ]; then parentId=null; fi
  if [ "$relation" == "null" ]; then relation=null; fi

  curl -s -X POST "$BASE_URL/context/push" \
    -H "Content-Type: application/json" \
    -d "{
      \"type\": \"$type\",
      \"tags\": \"$tags\",
      \"content\": \"$content\",
      \"parentId\": $parentId,
      \"relation\": $([ "$relation" = "null" ] && echo null || echo "\"$relation\"")
    }"

  echo ""

elif [ "$1" == "chat" ]; then
  shift
  prompt="$*"

  curl -s -X POST "$BASE_URL/chat" \
    -H "Content-Type: text/plain" \
    -d "$prompt"
  echo ""

else
  echo "Usage:"
  echo "  ctx push <TYPE> <tags> <content> [parentId] [relation]"
  echo "  ctx chat <prompt>"
fi
